# Ignore Visual Studio temporary files, build results, and user-specific files
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Ignore build output directories
bin/
obj/
out/

# Ignore NuGet packages
*.nupkg
packages/

# Ignore temporary files
*.tmp
*.temp
*.log
*.cache

# Ignore OS files
Thumbs.db
Desktop.ini
.DS_Store

# Ignore JetBrains Rider files
.idea/
*.sln.iml

# Ignore Node dependencies and logs if present
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore environment files
.env
.env.local
.env.*.local

# Ignore Rust build artifacts and local logs
target/
debug.log

# Ignore local tooling state
.agents/

# Ignore lock files generated by package managers if not committed
package-lock.json
yarn.lock
pnpm-lock.yaml
